# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_URL=https://your-app.vercel.app
BOT_API_SECRET=your_bot_api_secret_here

# ── Roblox account (bot) ─────────────────────────────────────────────────────
# Get cookie from browser DevTools → Application → Cookies → .ROBLOSECURITY
ROBLOX_COOKIE=_|WARNING:-DO-NOT-SHARE-THIS.--Steal...
BOT_ROBLOX_USERNAME=YourBotRobloxUsername

# ── Game settings ─────────────────────────────────────────────────────────────
GAME=MM2
# MM2 Roblox Place ID (Murder Mystery 2 = 142823291)
MM2_PLACE_ID=142823291

# ── Poll intervals (milliseconds) ─────────────────────────────────────────────
HEARTBEAT_INTERVAL_MS=30000
FRIEND_POLL_INTERVAL_MS=5000
PRESENCE_POLL_INTERVAL_MS=10000
