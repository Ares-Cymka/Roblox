# Neon PostgreSQL (pooler URL recommended)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
REDIS_URL=redis://localhost:6379
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-secure
SESSION_SECRET=change-me-to-a-long-random-string
APP_URL=http://localhost:3000
DELIVERY_ADAPTER=mock
DELIVERY_CONCURRENCY=5
