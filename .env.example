# Neon PostgreSQL (pooler URL recommended)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
REDIS_URL=redis://localhost:6379
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-secure
SESSION_SECRET=change-me-to-a-long-random-string
APP_URL=http://localhost:3000
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
DELIVERY_ADAPTER=mock
DELIVERY_CONCURRENCY=5
