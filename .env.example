# Neon PostgreSQL (pooler URL recommended)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
REDIS_URL=redis://localhost:6379
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-secure
SESSION_SECRET=change-me-to-a-long-random-string
APP_URL=http://localhost:3000

# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Delivery adapter:
#   manual = admin confirms in dashboard (default for production)
#   mock   = auto-simulates delivery (local dev/testing)
#   auto   = game-specific automation (placeholder until client confirms approach)
DELIVERY_ADAPTER=manual
DELIVERY_CONCURRENCY=5

# Bot controller settings (only relevant when running scripts/bot-worker.ts)
BOT_MOCK_DELAY_MS=3000
BOT_WORKER_POLL_MS=5000
BOT_WORKER_CONCURRENCY=3

# Shared secret for external bot agents calling /api/bot/callback and /api/bot/heartbeat
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOT_API_SECRET=

# MM2 delivery bot private server invite link (used when seeding/updating the MM2 bot account)
BOT_PRIVATE_SERVER_URL=https://www.roblox.com/share?code=967ed6cfb2218c48b5fb1ef2f9011b65&type=Server

# Seed MM2 test catalog, bot stock, and TESTPLAYER inventory (6 item types): npm run seed:mm2-testing
