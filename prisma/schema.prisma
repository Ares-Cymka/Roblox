generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameType {
  MM2
  ADOPT_ME
  SAB
  GAG2
  OTHER
}

enum OrderStatus {
  PENDING
  CLAIM_STARTED
  QUEUED
  PROCESSING
  DELIVERED
  FAILED
  CANCELLED
  EXPIRED
}

enum ClaimStatus {
  PENDING
  USERNAME_LINKED
  ORDER_READY
  WAITING_FRIEND_REQUEST
  WAITING_JOIN
  QUEUED
  PROCESSING
  DELIVERED
  FAILED
  CANCELLED
  EXPIRED
}

enum BotStatus {
  ONLINE
  OFFLINE
  BUSY
  DISABLED
}

enum BotAssignmentStatus {
  ASSIGNED
  FRIEND_REQUEST_PENDING
  FRIEND_REQUEST_SENT
  READY_TO_JOIN
  IN_GAME
  DELIVERING
  COMPLETED
  FAILED
  CANCELLED
}

enum DeliveryStatus {
  QUEUED
  PROCESSING
  WAITING_USER
  DELIVERED
  FAILED
  RETRYING
  CANCELLED
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  isActive     Boolean        @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]

  @@index([email])
}

model AdminSession {
  id          String     @id @default(cuid())
  adminUserId String?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  token       String     @unique
  expiresAt   DateTime
  createdAt   DateTime   @default(now())

  @@index([token])
  @@index([expiresAt])
  @@index([adminUserId])
}

model Customer {
  id              String   @id @default(cuid())
  email           String?  @unique
  robloxUsername  String?
  robloxUserId    String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
  claims          Claim[]

  @@index([robloxUsername])
  @@index([robloxUserId])
}

model Product {
  id             String          @id @default(cuid())
  game           GameType
  itemId         String
  name           String
  imageUrl       String?
  rarity         String?
  value          Decimal?        @db.Decimal(12, 2)
  stock          Int             @default(0)
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orderItems     OrderItem[]
  claimItems     ClaimItem[]
  botInventories BotInventory[]
  inventoryLogs  InventoryLog[]

  @@unique([game, itemId])
  @@index([game])
  @@index([name])
}

model Order {
  id         String      @id @default(cuid())
  orderCode  String      @unique
  status     OrderStatus @default(PENDING)
  customerId String?
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  items      OrderItem[]
  claims     Claim[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int      @default(1)
  unitValue Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  claimItems ClaimItem[]

  @@index([orderId])
  @@index([productId])
}

model Claim {
  id             String           @id @default(cuid())
  claimCode      String           @unique
  orderId        String
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  robloxUsername String?
  status         ClaimStatus      @default(PENDING)
  expiresAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  items          ClaimItem[]
  botAssignments BotAssignment[]
  deliveryJob    DeliveryJob?

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([robloxUsername])
  @@index([expiresAt])
}

model ClaimItem {
  id          String     @id @default(cuid())
  claimId     String
  claim       Claim      @relation(fields: [claimId], references: [id], onDelete: Cascade)
  productId   String
  product     Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  quantity    Int        @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([claimId])
  @@index([productId])
  @@index([orderItemId])
}

model BotAccount {
  id                      String          @id @default(cuid())
  game                    GameType
  robloxUsername          String
  robloxUserId            String?
  avatarUrl               String?
  profileUrl              String
  privateServerUrl        String?
  status                  BotStatus       @default(OFFLINE)
  maxConcurrentDeliveries Int             @default(1)
  currentDeliveries       Int             @default(0)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  inventories             BotInventory[]
  assignments             BotAssignment[]
  inventoryLogs           InventoryLog[]

  @@unique([game, robloxUsername])
  @@index([game])
  @@index([status])
  @@index([robloxUserId])
}

model BotInventory {
  id                String         @id @default(cuid())
  botAccountId      String
  botAccount        BotAccount     @relation(fields: [botAccountId], references: [id], onDelete: Cascade)
  productId         String
  product           Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity          Int            @default(0)
  reservedQuantity  Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  inventoryLogs     InventoryLog[]

  @@unique([botAccountId, productId])
  @@index([botAccountId])
  @@index([productId])
}

model BotAssignment {
  id            String              @id @default(cuid())
  botAccountId  String
  botAccount    BotAccount          @relation(fields: [botAccountId], references: [id], onDelete: Cascade)
  claimId       String
  claim         Claim               @relation(fields: [claimId], references: [id], onDelete: Cascade)
  status        BotAssignmentStatus @default(ASSIGNED)
  assignedAt    DateTime            @default(now())
  completedAt   DateTime?
  failureReason String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([botAccountId])
  @@index([claimId])
  @@index([status])
}

model DeliveryJob {
  id          String         @id @default(cuid())
  claimId     String         @unique
  claim       Claim          @relation(fields: [claimId], references: [id], onDelete: Cascade)
  status      DeliveryStatus @default(QUEUED)
  attempts    Int            @default(0)
  lastError   String?
  lockedAt    DateTime?
  deliveredAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  logs        DeliveryLog[]

  @@index([status])
  @@index([createdAt])
  @@index([lockedAt])
}

model DeliveryLog {
  id            String      @id @default(cuid())
  deliveryJobId String
  deliveryJob   DeliveryJob @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  level         LogLevel    @default(INFO)
  message       String
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([deliveryJobId])
  @@index([level])
  @@index([createdAt])
}

model InventoryLog {
  id              String        @id @default(cuid())
  botInventoryId  String?
  botInventory    BotInventory? @relation(fields: [botInventoryId], references: [id], onDelete: SetNull)
  botAccountId    String
  botAccount      BotAccount    @relation(fields: [botAccountId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  delta           Int
  quantityBefore  Int
  quantityAfter   Int
  reason          String
  metadata        Json?
  createdAt       DateTime      @default(now())

  @@index([botInventoryId])
  @@index([botAccountId])
  @@index([productId])
  @@index([createdAt])
}

model IdempotencyKey {
  id           String    @id @default(cuid())
  key          String    @unique
  scope        String
  requestHash  String?
  response     Json?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([scope])
  @@index([expiresAt])
}
