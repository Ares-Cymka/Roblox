generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameType {
  MM2
  ADOPT_ME
  SAB
  GAG2
  OTHER
}

enum DeliveryMethod {
  TRADING
  GIFTING
  MAILBOX
  JOIN_BASED
  MANUAL
}

enum OrderStatus {
  PENDING
  PAID
  INVENTORY_CREDITED
  CLAIM_STARTED
  QUEUED
  PROCESSING
  DELIVERED
  FAILED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CustomerInventoryLogReason {
  ORDER_PAID
  WITHDRAW_RESERVED
  WITHDRAW_DELIVERED
  WITHDRAW_CANCELLED
  ADMIN_ADJUSTMENT
}

enum ClaimStatus {
  PENDING
  USERNAME_LINKED
  ORDER_READY
  WAITING_FRIEND_REQUEST
  WAITING_JOIN
  QUEUED
  PROCESSING
  DELIVERED
  FAILED
  CANCELLED
  EXPIRED
}

enum WithdrawalStatus {
  PENDING
  USERNAME_REQUIRED
  QUEUED
  WAITING_FRIEND_REQUEST
  WAITING_JOIN
  PROCESSING
  DELIVERED
  FAILED
  CANCELLED
  SUPPORT_REQUIRED
}

enum BotStatus {
  ONLINE
  OFFLINE
  BUSY
  DISABLED
}

enum BotAssignmentStatus {
  ASSIGNED
  FRIEND_REQUEST_PENDING
  FRIEND_REQUEST_SENT
  READY_TO_JOIN
  IN_GAME
  DELIVERING
  COMPLETED
  FAILED
  CANCELLED
}

enum DeliveryStatus {
  QUEUED
  PROCESSING
  WAITING_USER
  DELIVERED
  FAILED
  RETRYING
  CANCELLED
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  isActive     Boolean        @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]

  @@index([email])
}

model AdminSession {
  id          String     @id @default(cuid())
  adminUserId String?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  token       String     @unique
  expiresAt   DateTime
  createdAt   DateTime   @default(now())

  @@index([token])
  @@index([expiresAt])
  @@index([adminUserId])
}

model Customer {
  id               String              @id @default(cuid())
  email            String?             @unique
  robloxUsername   String?
  robloxUserId     String?
  testCode         String?             @unique
  metadata         Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  orders           Order[]
  claims           Claim[]
  inventories      CustomerInventory[]
  withdrawals      Withdrawal[]
  inventoryLogs    CustomerInventoryLog[]

  @@index([robloxUsername])
  @@index([robloxUserId])
  @@index([testCode])
}

model Product {
  id                 String              @id @default(cuid())
  game               GameType
  itemId             String
  name               String
  imageUrl           String?
  rarity             String?
  value              Decimal?            @db.Decimal(12, 2)
  stock              Int                 @default(0)
  metadata           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orderItems         OrderItem[]
  claimItems         ClaimItem[]
  botInventories     BotInventory[]
  inventoryLogs      InventoryLog[]
  customerInventories CustomerInventory[]
  withdrawalItems    WithdrawalItem[]
  customerInventoryLogs CustomerInventoryLog[]

  @@unique([game, itemId])
  @@index([game])
  @@index([name])
}

model GameDeliveryConfig {
  id                        String         @id @default(cuid())
  game                      GameType       @unique
  deliveryMethod            DeliveryMethod
  requiresFriend            Boolean        @default(false)
  requiresPrivateServer       Boolean        @default(false)
  requiresCustomerJoin      Boolean        @default(false)
  requiresManualConfirmation Boolean       @default(true)
  instructions              String?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
}

model CustomerInventory {
  id                String    @id @default(cuid())
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sessionId         String?
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity          Int       @default(0)
  reservedQuantity  Int       @default(0)
  sourceOrderId     String?
  sourceOrder       Order?    @relation(fields: [sourceOrderId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([customerId])
  @@index([sessionId])
  @@index([productId])
  @@index([sourceOrderId])
}

model Withdrawal {
  id              String           @id @default(cuid())
  withdrawalCode  String           @unique
  customerId      String?
  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sessionId       String?
  robloxUsername  String?
  status          WithdrawalStatus @default(PENDING)
  totalValue      Decimal          @db.Decimal(12, 2)
  supportReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  items           WithdrawalItem[]
  botAssignments  BotAssignment[]
  deliveryJob     DeliveryJob?

  @@index([customerId])
  @@index([sessionId])
  @@index([status])
  @@index([robloxUsername])
}

model WithdrawalItem {
  id           String     @id @default(cuid())
  withdrawalId String
  withdrawal   Withdrawal @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity     Int        @default(1)
  unitValue    Decimal?   @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([withdrawalId])
  @@index([productId])
}

model Order {
  id                      String              @id @default(cuid())
  orderCode               String              @unique
  status                  OrderStatus         @default(PENDING)
  paymentStatus           PaymentStatus       @default(PENDING)
  customerId              String?
  customer                Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerEmail           String?
  sessionId               String?
  stripeCheckoutSessionId String?             @unique
  stripePaymentIntentId   String?             @unique
  totalAmount             Decimal?            @db.Decimal(12, 2)
  currency                String              @default("usd")
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  items                   OrderItem[]
  claims                  Claim[]
  customerInventories     CustomerInventory[]
  customerInventoryLogs   CustomerInventoryLog[]

  @@index([status])
  @@index([paymentStatus])
  @@index([customerId])
  @@index([customerEmail])
  @@index([sessionId])
  @@index([createdAt])
}

model OrderItem {
  id         String      @id @default(cuid())
  orderId    String
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Int         @default(1)
  unitValue  Decimal?    @db.Decimal(12, 2)
  unitPrice  Decimal?    @db.Decimal(12, 2)
  totalPrice Decimal?    @db.Decimal(12, 2)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  claimItems ClaimItem[]

  @@index([orderId])
  @@index([productId])
}

model CustomerInventoryLog {
  id         String                     @id @default(cuid())
  customerId String?
  customer   Customer?                  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sessionId  String?
  productId  String
  product    Product                    @relation(fields: [productId], references: [id], onDelete: Restrict)
  orderId    String?
  order      Order?                     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  delta      Int
  reason     CustomerInventoryLogReason
  createdAt  DateTime                   @default(now())

  @@index([customerId])
  @@index([sessionId])
  @@index([productId])
  @@index([orderId])
  @@index([reason])
  @@index([createdAt])
}

model Claim {
  id             String           @id @default(cuid())
  claimCode      String           @unique
  orderId        String
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  robloxUsername String?
  status         ClaimStatus      @default(PENDING)
  expiresAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  items          ClaimItem[]
  botAssignments BotAssignment[]
  deliveryJob    DeliveryJob?

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([robloxUsername])
  @@index([expiresAt])
}

model ClaimItem {
  id          String     @id @default(cuid())
  claimId     String
  claim       Claim      @relation(fields: [claimId], references: [id], onDelete: Cascade)
  productId   String
  product     Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  quantity    Int        @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([claimId])
  @@index([productId])
  @@index([orderItemId])
}

model BotAccount {
  id                      String          @id @default(cuid())
  game                    GameType
  robloxUsername          String
  robloxUserId            String?
  avatarUrl               String?
  profileUrl              String
  privateServerUrl        String?
  status                  BotStatus       @default(OFFLINE)
  maxConcurrentDeliveries Int             @default(1)
  currentDeliveries       Int             @default(0)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  inventories             BotInventory[]
  assignments             BotAssignment[]
  inventoryLogs           InventoryLog[]

  @@unique([game, robloxUsername])
  @@index([game])
  @@index([status])
  @@index([robloxUserId])
}

model BotInventory {
  id               String         @id @default(cuid())
  botAccountId     String
  botAccount       BotAccount     @relation(fields: [botAccountId], references: [id], onDelete: Cascade)
  productId        String
  product          Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity         Int            @default(0)
  reservedQuantity Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  inventoryLogs    InventoryLog[]

  @@unique([botAccountId, productId])
  @@index([botAccountId])
  @@index([productId])
}

model BotAssignment {
  id            String              @id @default(cuid())
  botAccountId  String
  botAccount    BotAccount          @relation(fields: [botAccountId], references: [id], onDelete: Cascade)
  claimId       String?
  claim         Claim?              @relation(fields: [claimId], references: [id], onDelete: Cascade)
  withdrawalId  String?
  withdrawal    Withdrawal?         @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  status        BotAssignmentStatus @default(ASSIGNED)
  assignedAt    DateTime            @default(now())
  completedAt   DateTime?
  failureReason String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([botAccountId])
  @@index([claimId])
  @@index([withdrawalId])
  @@index([status])
}

model DeliveryJob {
  id           String         @id @default(cuid())
  claimId      String?        @unique
  claim        Claim?         @relation(fields: [claimId], references: [id], onDelete: Cascade)
  withdrawalId String?        @unique
  withdrawal   Withdrawal?    @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  status       DeliveryStatus @default(QUEUED)
  attempts     Int            @default(0)
  lastError    String?
  lockedAt     DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  logs         DeliveryLog[]

  @@index([status])
  @@index([createdAt])
  @@index([lockedAt])
}

model DeliveryLog {
  id            String       @id @default(cuid())
  deliveryJobId String
  deliveryJob   DeliveryJob  @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  claimId       String?
  withdrawalId  String?
  level         LogLevel     @default(INFO)
  message       String
  metadata      Json?
  createdAt     DateTime     @default(now())

  @@index([deliveryJobId])
  @@index([claimId])
  @@index([withdrawalId])
  @@index([level])
  @@index([createdAt])
}

model InventoryLog {
  id             String        @id @default(cuid())
  botInventoryId String?
  botInventory   BotInventory? @relation(fields: [botInventoryId], references: [id], onDelete: SetNull)
  botAccountId   String
  botAccount     BotAccount    @relation(fields: [botAccountId], references: [id], onDelete: Cascade)
  productId      String
  product        Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  delta          Int
  quantityBefore Int
  quantityAfter  Int
  reason         String
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([botInventoryId])
  @@index([botAccountId])
  @@index([productId])
  @@index([createdAt])
}

model IdempotencyKey {
  id          String   @id @default(cuid())
  key         String   @unique
  scope       String
  requestHash String?
  response    Json?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([scope])
  @@index([expiresAt])
}
